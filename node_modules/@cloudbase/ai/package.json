{
  "name": "@cloudbase/ai",
  "version": "4.0.0",
  "description": "cloudbase js sdk ai module",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "miniprogram": "dist/miniprogram",
  "scripts": {
    "tsc": "rm -rf dist/ && tsc -p tsconfig.esm.json && tsc -p tsconfig.json",
    "lint": "eslint --fix \"./src/**/*.ts\"",
    "build": "npm run lint && npm run tsc && npm run build:mp",
    "tsc:mp": "tsc -p tsconfig.esm.json --outDir dist/miniprogram",
    "build:mp": "webpack --config ./webpack/webpack.miniprogram.js",
    "precommit": "npm run lint"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/TencentCloudBase/cloudbase-js-sdk"
  },
  "keywords": [
    "tcb",
    "cloudbase",
    "javascript",
    "typescript",
    "serverless"
  ],
  "author": "",
  "license": "Apache-2.0",
  "dependencies": {
    "@cloudbase/types": "4.0.0",
    "@cloudbase/utilities": "4.0.0",
    "@mattiasbuelens/web-streams-adapter": "^0.1.0",
    "text-encoding-shim": "^1.0.5",
    "web-streams-polyfill": "^4.0.0"
  },
  "devDependencies": {
    "@cloudbase/adapter-interface": "^0.7.1"
  },
  "gitHead": "e489e90352537598cac4ce36b64ed3184b0d41b1"
}
