{
  "name": "@cloudbase/oauth",
  "version": "2.25.7",
  "description": "cloudbase javascript sdk auth componets",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/cjs/index.d.ts",
  "miniprogram": "dist/miniprogram",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "eslint": "eslint \"{src,__tests__}/**/*.ts\"",
    "eslint:fix": "eslint --fix \"{src,__tests__}/**/*.ts\"",
    "clean": "rimraf dist",
    "tsc": "rm -rf dist/ && tsc -p tsconfig.esm.json && tsc -p tsconfig.json",
    "lint": "eslint --fix \"./src/**/*.ts\"",
    "build": "npm run lint && npm run tsc && npm run build:mp",
    "build:mp": "webpack --config ./webpack/webpack.miniprogram.js",
    "precommit": "npm run lint"
  },
  "dependencies": {
    "@cloudbase/utilities": "2.25.7"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.25.3",
    "@cloudbase/types": "2.25.7",
    "@types/node": "^22.5.4",
    "terser-webpack-plugin": "^3.0.2",
    "ts-loader": "^9.5.1",
    "webpack-bundle-analyzer": "^4.9.1"
  },
  "peerDependencies": {
    "@cloudbase/utilities": "2.25.0"
  },
  "license": "Apache-2.0",
  "gitHead": "dff517b083dfc0541d9fe66772d94be681a18be6"
}
